{
  "name": "fixforge-cli",
  "version": "1.1.1",
  "description": "AI-powered terminal code debugger & fixer using Groq LLM",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "bin": {
    "fixforge": "./dist/index.js"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "diff": "^5.2.0",
    "glob": "^10.3.10",
    "groq-sdk": "^0.7.0",
    "inquirer": "^9.2.12",
    "openai": "^4.28.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.3.3"
  },
  "type": "module",
  "keywords": [
    "cli",
    "ai",
    "debugging",
    "groq",
    "bun",
    "code-fixer"
  ],
  "license": "MIT"
}
